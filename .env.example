APP_NAME="Restaurant SaaS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_EG

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ───────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=restaurant_db
DB_USERNAME=root
DB_PASSWORD=

# ── Cache, Queue, Broadcast ────────────────────────────────────────────────────
# IMPORTANT: Never use "database" for queue in production — use Redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=reverb

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Reverb (Laravel WebSockets — self-hosted) ──────────────────────────────────
REVERB_APP_ID=restaurant
REVERB_APP_KEY=restaurant-key
REVERB_APP_SECRET=restaurant-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# ── Frontend URLs (separate projects) ─────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
POS_APP_URL=http://localhost:3001
KITCHEN_APP_URL=http://localhost:3002
RIDER_APP_URL=http://localhost:3003

# ── File Storage ───────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Mail ───────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@restoapp.eg"
MAIL_FROM_NAME="${APP_NAME}"

# ── Egyptian Tax Authority (ETA) ───────────────────────────────────────────────
ETA_CLIENT_ID=
ETA_CLIENT_SECRET=
ETA_PORTAL_URL=https://api.invoicing.eta.gov.eg
ETA_TOKEN_URL=https://id.eta.gov.eg/connect/token
ETA_CERT_PATH=storage/certs

# ── WhatsApp Business API (Meta) ───────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_API_VERSION=v19.0

# ── Paymob (subscription billing) ─────────────────────────────────────────────
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_CURRENCY=EGP
PAYMOB_BASE_URL=https://accept.paymob.com/api

# ── Fawry (alternative billing) ───────────────────────────────────────────────
FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=
FAWRY_BASE_URL=https://www.atfawry.com/ECommerceWeb/Fawry

# ── Billing ───────────────────────────────────────────────────────────────────
BILLING_GRACE_PERIOD_DAYS=7
BILLING_TRIAL_DAYS=14

# ── Scribe (API Documentation) ─────────────────────────────────────────────────
SCRIBE_AUTH_DEFAULT_VALUE=your-sanctum-token-here
